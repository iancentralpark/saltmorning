# Copy to .env and fill in (never commit .env)

PORT=8787
# Morning Class: paste your new spreadsheet ID here, then run npm run init-sheets -- --seed
SPREADSHEET_ID=1XNZYW16PWijfNZPe3knwLnTw5Be_x_BoCeL3G1WO7jg
TIMEZONE=Asia/Seoul

# --- Sheets (pick one) ---
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
# Railway: paste full JSON as one line instead of a file
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# --- Google Classroom OAuth (teacher account) ---
# Run: node scripts/oauth-setup.js
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8788/oauth2callback

# Optional: comma-separated origins for CORS
# CORS_ORIGINS=https://script.google.com

# Landing page — teacher gate (set on Railway; do not commit real password)
# TEACHER_GATE_PASSWORD=
# TEACHER_AUTH_SECRET=   # optional; signs teacher session tokens

# Class log spreadsheet (Mr. Park's Classes 2026)
# CLASS_LOG_SPREADSHEET_ID=1kUbo820pEzNThBmIQmwVi5MCd1O888y1rtuxz2IH4H4

# --- Supabase (Phase 1: classes + students + messages) ---
# Dashboard → Project Settings → API
# Project ref: tedzjzntesjslpiefbbi
SUPABASE_URL=https://tedzjzntesjslpiefbbi.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
# Set SUPABASE_ENABLED=false to force Google Sheets for Phase 1 tables
# SUPABASE_ENABLED=true
# Optional: keep Student_List col F in sync when passwords change (default off when Supabase on)
# SYNC_PASSWORDS_TO_SHEET=false
# Phase 2 (when Supabase on): dollars, attendance, homework, classroom_map
# Run server/supabase/migrations/002_phase2_all.sql then: npm run supabase:import-phase2
# Phase 3: chambit, textbooks, lucky draw, makeup, leave, library, sidebar, etc.
# Run server/supabase/migrations/003_phase3_all.sql then: npm run supabase:import-phase3
# Phase 4: class log daily + student marks (replaces class log spreadsheet writes)
# Run server/supabase/migrations/004_phase4_classlog.sql then: npm run supabase:import-phase4
# Phase 5: students.login_password (teacher-visible portal password)
# Run server/supabase/migrations/005_students_login_password.sql then: npm run supabase:backfill-passwords

# --- Telegram (student message alerts to teacher phone) ---
# TELEGRAM_BOT_TOKEN=   # from @BotFather
# TELEGRAM_CHAT_ID=     # your chat id (send /start to your bot, then getUpdates)
